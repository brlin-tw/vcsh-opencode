{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "model": "llama.cpp/default",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "default": {
          "name": "Default model",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  }
}
